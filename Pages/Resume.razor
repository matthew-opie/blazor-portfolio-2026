@code {
    private static string CalculateYearsBetweenDates(string startDate, string endDate)
    {
        var date1 = DateTime.Parse(startDate);
        var date2 = DateTime.Parse(endDate);
        return $"{(date2 - date1).TotalDays / 365.25:f2}";
    }
}
