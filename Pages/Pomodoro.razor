@page "/pomodoro"
@inject IJSRuntime JS
@inject IWebAssemblyHostEnvironment HostEnv
@implements IAsyncDisposable
@using System.Globalization
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting

<PageTitle>@PageTitle</PageTitle>

<div id="pomodoro" class="card @ModeClass">

    <div class="mode-tabs">
        @foreach (var mode in new[] { TimerMode.Pomodoro, TimerMode.ShortBreak, TimerMode.LongBreak })
        {
            var m = mode;
            var ms = _modes[m];
            <button class="tab @(CurrentMode == m ? "active" : "")"
                    @onclick="@(() => CurrentMode = m)">
                @TabLabel(m)
                @if (ms.State == TimerState.Running && CurrentMode != m)
                {
                    <span class="tab-dot"></span>
                }
            </button>
        }
    </div>

    <div class="ring-wrapper">
        <svg class="progress-ring" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <circle class="ring-bg"   cx="100" cy="100" r="88" />
            <circle class="ring-fill" cx="100" cy="100" r="88"
                    stroke-dasharray="@DashArray"
                    stroke-dashoffset="@DashOffset"
                    transform="rotate(-90 100 100)" />
        </svg>
        <div class="ring-content">
            <div class="time-display">@CurrentMs.TimeString</div>
            <div class="ring-label">@StateLabel</div>
        </div>
    </div>

    <div class="session-track">
        @for (int i = 0; i < 4; i++)
        {
            var idx = i;
            var filled = idx < PomodoroCount % 4
                      || (CurrentMs.State == TimerState.Alarm && CurrentMode == TimerMode.Pomodoro && idx == PomodoroCount % 4);
            <div class="session-dot @(filled ? "filled" : "")"></div>
        }
        <span class="session-label">Session @(PomodoroCount + 1)</span>
    </div>

    <div class="action-row">
        @if (CurrentMs.State == TimerState.Alarm)
        {
            <button class="btn-main" @onclick="StartSuggested">@SuggestedNextLabel</button>
            <button class="btn-minor" @onclick="ResetCurrent">Reset</button>
        }
        else
        {
            <button class="btn-main" @onclick="ToggleStartStop">
                @(CurrentMs.State == TimerState.Running ? "Pause" : "Start")
            </button>
            <button class="btn-minor" @onclick="ResetCurrent"
                    disabled="@(CurrentMs.State == TimerState.Init)">Reset</button>
        }
    </div>

    @if (_notificationBlocked)
    {
        <p class="notification-hint">
            <i class="fa-solid fa-bell-slash"></i>
            Notifications blocked — enable them in browser settings.
        </p>
    }

    @if (HostEnv.IsDevelopment())
    {
        <button class="debug-btn" @onclick="TestNotification" title="Test browser notification">
            <i class="fa-solid fa-bug"></i> Test Notification
        </button>
    }

</div>

@code {

    private const string NotificationIcon = "./images/icons/clock-red.png";

    private static readonly Dictionary<TimerMode, int> Durations = new()
    {
        [TimerMode.Pomodoro]   = 1500,
        [TimerMode.ShortBreak] = 300,
        [TimerMode.LongBreak]  = 900,
    };

    private const double Radius        = 88;
    private const double Circumference = 2 * Math.PI * Radius;

    // Per-mode state — each tab has its own timer
    private class ModeState
    {
        public int        Total         { get; init; }
        public int        TimeRemaining { get; set; }
        public TimerState State         { get; set; } = TimerState.Init;
        public string     TimeString    { get; set; }

        public ModeState(int total)
        {
            Total         = total;
            TimeRemaining = total;
            TimeString    = FormatTime(total);
        }

        public static string FormatTime(int seconds) =>
            $"{seconds / 60}:{seconds % 60:D2}";
    }

    private readonly Dictionary<TimerMode, ModeState> _modes = new()
    {
        [TimerMode.Pomodoro]   = new(1500),
        [TimerMode.ShortBreak] = new(300),
        [TimerMode.LongBreak]  = new(900),
    };

    // Convenience — the mode currently on screen
    private ModeState CurrentMs => _modes[CurrentMode];

    private TimerMode CurrentMode   { get; set; } = TimerMode.Pomodoro;
    private int       PomodoroCount { get; set; } = 0;
    private bool      _notificationBlocked;
    private CancellationTokenSource? _cts;
    private TimerMode? _runningMode; // which mode's loop is ticking

    // SVG ring — driven by the viewed mode
    private string DashArray  => Circumference.ToString("F2", CultureInfo.InvariantCulture);
    private string DashOffset
    {
        get
        {
            var ms       = CurrentMs;
            var progress = ms.Total > 0 ? (double)ms.TimeRemaining / ms.Total : 0d;
            return (Circumference * (1d - progress)).ToString("F2", CultureInfo.InvariantCulture);
        }
    }

    private string ModeClass => CurrentMode switch
    {
        TimerMode.ShortBreak => "mode-short-break",
        TimerMode.LongBreak  => "mode-long-break",
        _                    => "mode-pomodoro",
    };

    private string PageTitle
    {
        get
        {
            // Show the running timer in the tab, regardless of what's viewed
            if (_runningMode.HasValue)
            {
                var rs = _modes[_runningMode.Value];
                return $"{rs.TimeString} — {ModeName(_runningMode.Value)}";
            }
            return CurrentMs.State switch
            {
                TimerState.Alarm   => "Time's Up!",
                TimerState.Stopped => $"{CurrentMs.TimeString} (Paused)",
                _                  => "mattopie.com — Tomato Timer",
            };
        }
    }

    private string StateLabel => CurrentMs.State switch
    {
        TimerState.Running => ModeName(CurrentMode),
        TimerState.Stopped => "Paused",
        TimerState.Alarm   => "Done!",
        _                  => ModeName(CurrentMode),
    };

    private TimerMode SuggestedNext => CurrentMode switch
    {
        TimerMode.Pomodoro when PomodoroCount % 4 == 3 => TimerMode.LongBreak,
        TimerMode.Pomodoro                             => TimerMode.ShortBreak,
        _                                              => TimerMode.Pomodoro,
    };

    private string SuggestedNextLabel => SuggestedNext switch
    {
        TimerMode.LongBreak  => "Take Long Break \u2192",
        TimerMode.ShortBreak => "Take Short Break \u2192",
        _                    => "Start Pomodoro \u2192",
    };

    private static string ModeName(TimerMode mode) => mode switch
    {
        TimerMode.ShortBreak => "Short Break",
        TimerMode.LongBreak  => "Long Break",
        _                    => "Focus",
    };

    private static string TabLabel(TimerMode mode) => mode switch
    {
        TimerMode.ShortBreak => "Short Break",
        TimerMode.LongBreak  => "Long Break",
        _                    => "Pomodoro",
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var supported = await JS.InvokeAsync<bool>("notifications.isSupported");
            if (supported)
            {
                var permission = await JS.InvokeAsync<string>("notifications.requestPermission");
                _notificationBlocked = permission == "denied";
                StateHasChanged();
            }
        }
    }

    private void ToggleStartStop()
    {
        if (CurrentMs.State == TimerState.Running)
            PauseCurrent();
        else
            StartCurrent();
    }

    private void StartCurrent()
    {
        if (CurrentMs.State == TimerState.Running) return;

        // Pause any other running mode first
        if (_runningMode.HasValue && _runningMode.Value != CurrentMode)
        {
            _modes[_runningMode.Value].State = TimerState.Stopped;
        }

        CancelRun();
        CurrentMs.State = TimerState.Running;
        _runningMode    = CurrentMode;
        _cts            = new CancellationTokenSource();
        _ = RunAsync(CurrentMode, _cts.Token);
    }

    private void PauseCurrent()
    {
        CancelRun();
        CurrentMs.State = TimerState.Stopped;
        _runningMode    = null;
    }

    private void ResetCurrent()
    {
        // Only cancel if THIS mode is the one running
        if (_runningMode == CurrentMode)
        {
            CancelRun();
            _runningMode = null;
        }
        CurrentMs.State         = TimerState.Init;
        CurrentMs.TimeRemaining = CurrentMs.Total;
        CurrentMs.TimeString    = ModeState.FormatTime(CurrentMs.Total);
    }

    private void StartSuggested()
    {
        if (CurrentMode == TimerMode.Pomodoro)
            PomodoroCount++;

        var next = SuggestedNext;

        // Reset the just-completed mode
        CurrentMs.State         = TimerState.Init;
        CurrentMs.TimeRemaining = CurrentMs.Total;
        CurrentMs.TimeString    = ModeState.FormatTime(CurrentMs.Total);

        CurrentMode = next;
        StartCurrent();
    }

    private void CancelRun()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = null;
    }

    private async Task RunAsync(TimerMode mode, CancellationToken ct)
    {
        var ms = _modes[mode];

        while (ms.TimeRemaining > 0)
        {
            try { await Task.Delay(1000, ct); }
            catch (OperationCanceledException) { return; }

            ms.TimeRemaining--;
            ms.TimeString = ModeState.FormatTime(ms.TimeRemaining);
            StateHasChanged();

            if (ms.TimeRemaining == 0)
            {
                _runningMode = null;
                await TriggerAlarmAsync(mode);
                return;
            }
        }
    }

    private async Task TriggerAlarmAsync(TimerMode mode)
    {
        _modes[mode].State = TimerState.Alarm;
        CurrentMode        = mode; // bring the user back to see the alarm
        StateHasChanged();
        try
        {
            var title = mode == TimerMode.Pomodoro ? "Focus session complete!" : "Break's over!";
            await JS.InvokeVoidAsync("notifications.show", title, SuggestedNextLabel, NotificationIcon);
        }
        catch { /* page may be unloading */ }
    }

    private async Task TestNotification()
    {
        try
        {
            await JS.InvokeVoidAsync("notifications.show",
                "Test Notification", "Pomodoro notifications are working!", NotificationIcon);
        }
        catch { }
    }

    public ValueTask DisposeAsync()
    {
        CancelRun();
        return ValueTask.CompletedTask;
    }

    public enum TimerState { Init, Stopped, Running, Alarm }
    public enum TimerMode  { Pomodoro, ShortBreak, LongBreak }
}
