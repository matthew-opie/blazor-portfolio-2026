@page "/"
<PageTitle>mattopie.com</PageTitle>

<div class="hero">
    <div class="hero-content">
        <p class="hero-eyebrow">Hi, I'm</p>
        <h1 id="name">Matt Opie</h1>
        <h2 class="hero-sub">Senior Software Engineer</h2>
        <p class="hero-location">
            <i class="fa-solid fa-location-dot"></i> Boston, MA
        </p>
        <div class="hero-cta">
            <a class="btn-primary" href="resume">View Résumé</a>
            <a class="btn-secondary" href="portfolio">See Projects</a>
        </div>
    </div>
</div>

<div class="bio-card card">
    <div class="bio-photo">
        <img class="headshot" src="images/headshot-business-card.png" alt="Matt Opie" />
    </div>
    <div class="bio-text">
        <p>
            Full-stack software engineer with a background in electrical engineering and 7+ years of experience
            building enterprise applications. Currently working as a lead consultant, owning end-to-end feature
            delivery for a large-scale insurance platform built on .NET and Vue.js.
        </p>
        <p>
            Previously at Johnson &amp; Johnson Vision, where I co-invented a U.S.-patented computer-vision
            quality control system using MATLAB-based machine learning and led capital projects up to $600K.
        </p>
    </div>
</div>
